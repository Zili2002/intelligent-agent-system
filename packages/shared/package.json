{
  "name": "@intelligent-agent/shared",
  "version": "0.2.0",
  "description": "Shared utilities and types for intelligent agent system",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/**/*.test.ts",
    "lint": "tsc --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "keywords": [
    "agent",
    "sync",
    "types"
  ],
  "author": "linzili",
  "license": "MIT"
}
