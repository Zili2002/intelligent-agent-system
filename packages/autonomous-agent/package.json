{
  "name": "autonomous-agent",
  "version": "0.3.1",
  "description": "Mission-driven autonomous exploration system",
  "type": "module",
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "bin": {
    "autonomous-agent": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/**/*.test.ts",
    "test:docker": "tsx --test test/docker.integration.ts",
    "lint": "tsc --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "ai",
    "agent",
    "autonomous",
    "exploration",
    "research"
  ],
  "author": "Claude Code",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@intelligent-agent/shared": "0.2.0",
    "@intelligent-agent-system/llm-wiki-compiler": "0.3.0",
    "commander": "^15.0.0",
    "dockerode": "^5.0.1",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/dockerode": "4.0.1"
  }
}
