{
  "name": "@intelligent-agent-system/research-reader",
  "version": "0.1.0",
  "description": "Evidence-grounded literature tracking and research reading workflows",
  "type": "module",
  "bin": {
    "research-reader": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test test/*.test.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@intelligent-agent-system/llm-wiki-compiler": "1.5.0",
    "@intelligent-agent/shared": "0.3.0",
    "commander": "14.0.3"
  },
  "devDependencies": {
    "@types/node": "26.1.0",
    "tsx": "4.23.0",
    "typescript": "6.0.3"
  },
  "license": "MIT"
}
