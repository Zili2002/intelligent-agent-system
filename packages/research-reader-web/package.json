{
  "name": "@intelligent-agent-system/research-reader-web",
  "version": "0.1.0",
  "description": "Local-only PDF and evidence reader for Research Reader",
  "private": true,
  "type": "module",
  "bin": {
    "research-reader-web": "./dist/server/cli.js"
  },
  "main": "./dist/server/index.js",
  "types": "./dist/server/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    }
  },
  "scripts": {
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "tsx --test test/*.test.ts",
    "lint": "npm run typecheck && prettier --check \"src/**/*.{ts,tsx,css}\" \"test/**/*.ts\" \"vite.config.ts\"",
    "dev": "vite",
    "start": "node dist/server/cli.js",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@intelligent-agent-system/llm-wiki-compiler": "1.5.0",
    "@intelligent-agent-system/research-reader": "0.1.0",
    "commander": "14.0.3",
    "pdfjs-dist": "5.4.624",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@types/node": "26.1.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.4.1",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "vite": "6.4.3"
  },
  "license": "MIT"
}
